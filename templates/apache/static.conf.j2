{# ---
variables:
  - name: domain
    description: "The fully-qualified domain name for the virtual host."
  - name: port
    description: "HTTP port the VirtualHost block listens on."
    default: "80"
  - name: document_root
    description: "Absolute path to the site web root directory."
  - name: os_family
    description: "OS family: debian_family or rhel_family (controls log path)."
  - name: use_ssl
    description: "When true, renders a 443 SSL block and HTTP→HTTPS redirect."
    default: false
  - name: cert_path
    description: "Absolute path to the SSL certificate (.pem). Required when use_ssl=true."
  - name: key_path
    description: "Absolute path to the SSL private key (-key.pem). Required when use_ssl=true."
--- #}
{% if domain.startswith('www.') %}
{% set redirect_domain = domain[4:] %}
{% else %}
{% set redirect_domain = 'www.' ~ domain %}
{% endif %}

{% if use_ssl %}
# ============================================================
# HTTP → HTTPS redirect — {{ domain }}
# ============================================================
<VirtualHost *:80>
    ServerName {{ domain }}
    ServerAlias {{ redirect_domain }}
    RewriteEngine On
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</VirtualHost>

# ============================================================
# HTTPS static site — {{ domain }}
# ============================================================
<VirtualHost *:443>
    ServerName {{ domain }}

    SSLEngine on
    SSLCertificateFile {{ cert_path }}
    SSLCertificateKeyFile {{ key_path }}
    {% if os_family == 'debian_family' %}
    Protocols h2 http/1.1
    {% endif %}

    DocumentRoot "{{ document_root }}"

    <Directory "{{ document_root }}">
        Options -Indexes +FollowSymLinks
        AllowOverride None
        Require all granted
    </Directory>

    DirectoryIndex index.html

{% if php_socket %}
    DirectoryIndex index.php index.html
    <FilesMatch \.php$>
        SetHandler "proxy:unix:{{ php_socket }}|fcgi://localhost"
    </FilesMatch>
{% endif %}

    {% if os_family == 'rhel_family' %}
    ErrorLog /var/log/httpd/{{ domain }}-error.log
    CustomLog /var/log/httpd/{{ domain }}-access.log combined
    {% else %}
    ErrorLog ${APACHE_LOG_DIR}/{{ domain }}-error.log
    CustomLog ${APACHE_LOG_DIR}/{{ domain }}-access.log combined
    {% endif %}
</VirtualHost>

# ============================================================
# HTTPS canonical redirect: {{ redirect_domain }} → {{ domain }} (301)
# ============================================================
<VirtualHost *:443>
    ServerName {{ redirect_domain }}
    SSLEngine on
    SSLCertificateFile {{ cert_path }}
    SSLCertificateKeyFile {{ key_path }}
    Redirect permanent / https://{{ domain }}/
</VirtualHost>
{% else %}
# ============================================================
# Static site — {{ domain }}
# ============================================================
<VirtualHost *:{{ port }}>
    ServerName {{ domain }}
    DocumentRoot "{{ document_root }}"

    <Directory "{{ document_root }}">
        Options -Indexes +FollowSymLinks
        AllowOverride None
        Require all granted
    </Directory>

    DirectoryIndex index.html

{% if php_socket %}
    DirectoryIndex index.php index.html
    <FilesMatch \.php$>
        SetHandler "proxy:unix:{{ php_socket }}|fcgi://localhost"
    </FilesMatch>
{% endif %}

    {% if os_family == 'rhel_family' %}
    ErrorLog /var/log/httpd/{{ domain }}-error.log
    CustomLog /var/log/httpd/{{ domain }}-access.log combined
    {% else %}
    ErrorLog ${APACHE_LOG_DIR}/{{ domain }}-error.log
    CustomLog ${APACHE_LOG_DIR}/{{ domain }}-access.log combined
    {% endif %}
</VirtualHost>

# ============================================================
# Canonical redirect: {{ redirect_domain }} → {{ domain }} (301)
# ============================================================
<VirtualHost *:{{ port }}>
    ServerName {{ redirect_domain }}
    Redirect permanent / http://{{ domain }}{% if port != 80 and port != 443 %}:{{ port }}{% endif %}/
</VirtualHost>
{% endif %}
