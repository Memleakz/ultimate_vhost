{# ---
variables:
  - name: domain
    description: "The fully-qualified domain name for the virtual host."
  - name: port
    description: "HTTP port the VirtualHost block listens on."
    default: "80"
  - name: document_root
    description: "Absolute path to the site web root directory."
  - name: os_family
    description: "OS family: debian_family or rhel_family (controls log path)."
--- #}
{% if domain.startswith('www.') %}
{% set redirect_domain = domain[4:] %}
{% else %}
{% set redirect_domain = 'www.' ~ domain %}
{% endif %}

# ============================================================
# Static site — {{ domain }}
# ============================================================
<VirtualHost *:{{ port }}>
    ServerName {{ domain }}
    DocumentRoot "{{ document_root }}"

    <Directory "{{ document_root }}">
        Options -Indexes +FollowSymLinks
        AllowOverride None
        Require all granted
    </Directory>

    DirectoryIndex index.html

    {% if os_family == 'rhel_family' %}
    ErrorLog /var/log/httpd/{{ domain }}-error.log
    CustomLog /var/log/httpd/{{ domain }}-access.log combined
    {% else %}
    ErrorLog ${APACHE_LOG_DIR}/{{ domain }}-error.log
    CustomLog ${APACHE_LOG_DIR}/{{ domain }}-access.log combined
    {% endif %}
</VirtualHost>

# ============================================================
# Canonical redirect: {{ redirect_domain }} → {{ domain }} (301)
# ============================================================
<VirtualHost *:{{ port }}>
    ServerName {{ redirect_domain }}
    Redirect permanent / http://{{ domain }}{% if port != 80 and port != 443 %}:{{ port }}{% endif %}/
</VirtualHost>
