<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ domain | default('localhost') }}</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: #0f172a;
            color: #e2e8f0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .card {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 1rem;
            padding: 3rem 4rem;
            text-align: center;
            max-width: 640px;
            width: 100%;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
        }
        .badge {
            display: inline-block;
            background: #10b981;
            color: #ffffff;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            margin-bottom: 1.5rem;
        }
        h1 {
            font-size: 3rem;
            font-weight: 800;
            color: #f8fafc;
            margin-bottom: 0.5rem;
        }
        .domain {
            font-size: 1.25rem;
            color: #94a3b8;
            margin-bottom: 2rem;
            word-break: break-all;
        }
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
            margin-bottom: 2rem;
            text-align: left;
        }
        .info-item {
            background: #0f172a;
            border: 1px solid #1e293b;
            border-radius: 0.5rem;
            padding: 0.75rem 1rem;
        }
        .info-label {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #64748b;
            margin-bottom: 0.25rem;
        }
        .info-value {
            font-size: 0.85rem;
            color: #cbd5e1;
            word-break: break-all;
        }
        footer {
            margin-top: 2rem;
            font-size: 0.8rem;
            color: #475569;
        }
        footer strong {
            color: #64748b;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="badge">&#10003; Virtual Host Active</div>
        <h1>It works!</h1>
        <p class="domain">{{ domain | default('localhost') }}</p>


        <footer>
            Powered by {{ tool_name | default('ultimate_vhost') }}{% if tool_version %} {{ tool_version }}{% endif %}
        </footer>
    </div>
</body>
</html>
