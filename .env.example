# ==============================================================================
# VHOST HELPER - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' before starting the Docker Compose stack:
#   cp .env.example .env
#
# Uncomment and set any value to override the system default.
# All path overrides require VHOST_TEST_MODE=1 to take effect.

# --- Security & Testing -------------------------------------------------------
# Set to 1 to enable environment-variable path overrides (dev/CI only).
# Must be 0 or unset in production so the tool uses real system paths.
VHOST_TEST_MODE=0

# --- Nginx Paths --------------------------------------------------------------
# Directory where Nginx virtual host configuration files are stored.
# NGINX_SITES_AVAILABLE=/etc/nginx/sites-available

# Directory where symlinks to enabled Nginx configurations are stored.
# NGINX_SITES_ENABLED=/etc/nginx/sites-enabled

# Directory where disabled Nginx configurations are stored (RHEL-style).
# NGINX_SITES_DISABLED=/etc/nginx/conf.disabled

# --- Apache Paths -------------------------------------------------------------
# Directory where Apache virtual host configuration files are stored.
# APACHE_SITES_AVAILABLE=/etc/apache2/sites-available

# Directory where symlinks to enabled Apache configurations are stored (Debian).
# APACHE_SITES_ENABLED=/etc/apache2/sites-enabled

# Directory where disabled Apache configurations are stored (RHEL-style).
# APACHE_SITES_DISABLED=/etc/httpd/conf.disabled

# --- System Paths -------------------------------------------------------------
# Path to the system hosts file. Override for dev/test to avoid touching real /etc/hosts.
# VHOST_HOSTS_FILE=/etc/hosts

# --- Tooling ------------------------------------------------------------------
# Logging verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
